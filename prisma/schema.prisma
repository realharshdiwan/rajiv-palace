generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id        Int      @id @default(autoincrement())
  name      String
  location  String
  rating    Float
  highlight String
  createdAt DateTime @default(now())
}

model Room {
  id          Int      @id @default(autoincrement())
  name        String
  price       Int
  maxGuests   Int
  description String?
  images      String[]
  size        String?
  view        String?
  bed         String?
  amenities   String[]
  totalRooms  Int      @default(1)
  createdAt   DateTime @default(now())
  bookings    Booking[]
}

model Booking {
  id        Int      @id @default(autoincrement())
  roomId    Int
  checkIn   DateTime
  checkOut  DateTime
  status    String   // pending, confirmed, cancelled
  name      String
  phone     String
  email     String?
  expiresAt DateTime? // For the 10-minute hold
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
}
